{
  "extends": "../../packages/tsconfig/next-bun-experimental.json",
  "compilerOptions": {
    "target": "ES2023",
    // "lib": ["dom", "dom.iterable", "esnext"],
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    // "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["./components/*"],
      "@/lib/*": ["./lib/*"],
      "@/hooks/*": ["./lib/hooks/*"],
      "@/styles/*": ["./lib/styles/*"],
      "@/integrations/*": ["./lib/integrations/*"],
      "@/webgl/*": ["./lib/webgl/*"],
      "@/utils/*": ["./lib/utils/*"],
      "@/config": ["./lib/styles/config.ts"],
      "@/dev/*": ["./lib/dev/*"],
      "@/dev/theatre/*": ["./lib/dev/theatre/*"],
      "@/dev/theatre": ["./lib/dev/theatre"],
      "@/dev": ["./lib/dev"]
    }
  },
  "include": [
    "next-env.d.ts",
    "lib/utils/types.d.ts",
    "lib/utils/css.d.ts",
    "**/*.js",
    "**/*.jsx",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
