# Gravii User Landing environment

# Base URL for canonical URLs and metadata.
# Development: http://localhost:3000
# Production: https://gravii.io
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Launch destination for the header CTA.
# Fallback: https://app.gravii.io
# Local user-app example, when that app is running: http://localhost:3001
# NEXT_PUBLIC_USER_APP_URL="http://localhost:3001"

# Partner product destination used by /partners.
# Development fallback: http://localhost:3001
# Production fallback: https://partner.gravii.io
# NEXT_PUBLIC_PARTNER_APP_URL="http://localhost:3001"

# Landing API endpoint used by the waitlist server action.
# Defaults to https://api.gravii.io when unset.
# NEXT_PUBLIC_GRAVII_LANDING_API_BASE_URL="https://api.gravii.io"
# GRAVII_LANDING_API_BASE_URL="https://api.gravii.io"

# Enable production browser source maps when set to true.
# SOURCE_MAPS="true"

# Enable Next bundle analysis when set to true.
# ANALYZE="true"

# Optional social metadata.
# NEXT_PUBLIC_FACEBOOK_APP_ID=""

# Vercel-populated variables are consumed automatically when present.
# VERCEL_URL=""
# VERCEL_ENV=""
# VERCEL_OIDC_TOKEN=""
