{
  "name": "gravii-frontend-operations",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "bun run typecheck && bun run lint",
    "verify": "bun run check && bun run build",
    "test:e2e": "playwright test",
    "typecheck:user-landing": "turbo run typecheck --filter=gravii-user-landing",
    "check:user-landing": "bun run typecheck:user-landing && bun run lint:user-landing",
    "dev:backoffice": "turbo run dev --filter=gravii-backoffice",
    "dev:user-landing": "turbo run dev --filter=gravii-user-landing",
    "dev:user-app": "turbo run dev --filter=gravii-user-app",
    "dev:partner-app": "turbo run dev --filter=gravii-partner-app",
    "build:backoffice": "turbo run build --filter=gravii-backoffice",
    "build:user-landing": "turbo run build --filter=gravii-user-landing",
    "build:user-app": "turbo run build --filter=gravii-user-app",
    "build:partner-app": "turbo run build --filter=gravii-partner-app",
    "lint:user-landing": "turbo run lint --filter=gravii-user-landing"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "turbo": "2.8.17"
  },
  "overrides": {
    "@babel/plugin-transform-modules-systemjs": "7.29.4",
    "axios": "1.16.0",
    "basic-ftp": "5.3.1",
    "brace-expansion": "1.1.14",
    "dompurify": "3.4.2",
    "follow-redirects": "1.16.0",
    "js-yaml": "3.14.2",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "picomatch": "2.3.2",
    "postcss": "8.5.14",
    "protobufjs": "7.5.7",
    "smol-toml": "1.6.1",
    "uuid": "13.0.2",
    "vite": "7.3.3",
    "yaml": "2.9.0"
  }
}
